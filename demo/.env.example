# ─── TradingAgents Demo — API Keys ───────────────────────────────────────────
# Copy this file to demo/.env and fill in your values.
# NEVER commit demo/.env to Git.

# Required
OPENAI_API_KEY=sk-your-openai-key-here
FINNHUB_API_KEY=your-finnhub-key-here

# Optional (enables news-based analysis)
TAVILY_API_KEY=your-tavily-key-here

# Demo settings (override config/demo_config.yaml)
DEMO_SYMBOLS=AAPL,MSFT,NVDA
DEMO_INITIAL_CAPITAL=100000
DEMO_DRY_RUN=true
